# BuildTrack API — Production Environment
# Copy to .env and fill in your values
# DO NOT commit .env to git

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/buildtrack

# JWT (generate strong secrets with: openssl rand -hex 64)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Server
PORT=3001
NODE_ENV=development
API_URL=http://localhost:3001

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:3000,http://localhost:8081,exp://localhost:19000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# File Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Logging
LOG_LEVEL=info

# MinIO S3 Storage
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET=buildtrack-uploads
MINIO_REGION=us-east-1

# Email
# Preferred: Brevo HTTP API (300/day free; domain auth on @cortexbuildpro.com).
# Get a key from https://app.brevo.com/settings/keys/api. Domain or single-sender
# verification is required by Brevo before sends will succeed.
BREVO_API_KEY=
EMAIL_FROM=noreply@cortexbuildpro.com
EMAIL_FROM_NAME=BuildTrack
# Fallback: SMTP (only used if BREVO_API_KEY is unset). Leave empty in prod.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Reset-link base URL emailed by /forgot-password.
APP_URL=https://buildtrack.cortexbuildpro.com
